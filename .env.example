# Gemini API Keys (画像生成・AI書き換え用)
# Google AI Studio で取得: https://aistudio.google.com/apikey
GEMINI_API_KEY_1=your_key_here
GEMINI_API_KEY_2=your_key_here
GEMINI_API_KEY_3=your_key_here

# 単一キーの場合はこちらでもOK
# GEMINI_API_KEY=your_key_here

# サーバーポート (デフォルト: 3000)
# PORT=3000

# ── 広告プラットフォーム ──────────────────────────

